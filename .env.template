# ==============================================================================
# TCP Proxy Configuration Template
# Скопируйте этот файл, переименуйте в .env и укажите свои значения.
# ==============================================================================

# Порт, который будет слушать данный прокси-сервер
LISTEN_PORT=3000

# Сетевой интерфейс для прослушивания
# 0.0.0.0 — принимать подключения со всех интерфейсов (из внешней сети)
# 127.0.0.1 — принимать подключения только локально с этой же машины
LISTEN_HOST=0.0.0.0

# IP-адрес или хост целевого сервиса, куда нужно перенаправлять трафик
TARGET_HOST=127.0.0.1

# Порт целевого сервиса, который вы хотите пробросить
TARGET_PORT=8080
